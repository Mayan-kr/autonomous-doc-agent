# Streamlit secrets template.
#
# LOCAL DEV: you don't need this file — the app reads your .env instead.
# STREAMLIT CLOUD: copy these keys into the app's Settings -> Secrets box
#                  (do NOT commit a real secrets.toml).
GROQ_API_KEY = "your_groq_api_key_here"

# Optional overrides
GROQ_MODEL = "llama-3.3-70b-versatile"
GROQ_FALLBACK_MODEL = "llama-3.1-8b-instant"
